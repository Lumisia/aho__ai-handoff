{
  "type": "object",
  "required": ["schema_version", "capsule_id", "task_id", "created_at", "source", "target", "checkpoint", "task", "integrity"],
  "properties": {
    "schema_version": { "type": "string" },
    "capsule_id": { "type": "string" },
    "task_id": { "type": "string" },
    "created_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "source": { "type": "object", "required": ["agent"], "properties": { "agent": { "type": "string" } } },
    "target": { "type": "object", "required": ["agent"], "properties": { "agent": { "type": "string" } } },
    "checkpoint": {
      "type": "object",
      "required": ["status"],
      "properties": { "status": { "type": "string", "enum": ["in_progress", "blocked", "completed"] } }
    },
    "task": {
      "type": "object",
      "required": ["goal"],
      "properties": {
        "goal": { "type": "string" },
        "next_actions": { "type": "array", "items": { "type": "string" } },
        "completed": { "type": "array", "items": { "type": "string" } },
        "open_issues": { "type": "array", "items": { "type": "string" } },
        "changed_files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "integrity": { "type": "object", "required": ["payload_sha256"], "properties": { "payload_sha256": { "type": "string" } } }
  }
}
