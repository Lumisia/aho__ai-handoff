{
  "type": "object",
  "required": ["schema_version", "shard_id", "created_at", "project", "fact", "evidence", "verified", "integrity"],
  "properties": {
    "schema_version": { "type": "string" },
    "shard_id": { "type": "string" },
    "created_at": { "type": "string" },
    "project": { "type": "object", "required": ["fingerprint"], "properties": { "fingerprint": { "type": "string" } } },
    "fact": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "object", "required": ["type", "value"], "properties": { "type": { "type": "string" }, "value": { "type": "string" } } } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "paths": { "type": "array", "items": { "type": "string" } },
    "branch": { "type": "string" },
    "verified": { "type": "boolean" },
    "integrity": { "type": "object", "required": ["payload_sha256"], "properties": { "payload_sha256": { "type": "string" } } }
  }
}
